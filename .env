PROXY=""

# ===== MODE — PAPER TRADING (zero real money risk) =====
PAPER_TRADING=true
ENABLE_LIVE_TRADING=false
ALLOW_REAL_ORDERS=false
CONFIRM_LIVE_TRADING=false
LOG_LEVEL=INFO

# ===== PORTFOLIO — $100 START =====
STARTING_PORTFOLIO=100.0
MAX_POSITION_PCT=0.125           # 12.5% per trade (~$12.50 risk on $100) — aggressive but controlled
DAILY_DRAWDOWN_LIMIT=0.12        # Kill switch at 12% drawdown (~$12 loss)

# ===== STRATEGY — AGGRESSIVE BUT FILTERED =====
EDGE_TRIGGER_PCT=0.024           # Scan more opportunities
MIN_EDGE_TO_EXECUTE=0.037        # 3.7%+ net edge required (sweet spot for frequency + quality)
MIN_CONFIDENCE_SCORE=0.69        # Good balance — not too strict
KELLY_FRACTION=0.27              # ~quarter-Kelly → aggressive sizing without full Kelly danger

# ===== FEES =====
FEE_BUFFER_PCT=0.022             # 2.2% total buffer

# ===== TP/SL (kept for compatibility — bot still holds to resolution) =====
TAKE_PROFIT_PCT=0.055
STOP_LOSS_PCT=0.045

# ===== FILTERS — LOOSENED FOR MORE ACTION =====
MULTI_TF_CONFIRMATION=true
MAX_SPREAD_PCT=0.055             # Allow slightly wider spreads for more trades
MIN_BOOK_DEPTH=18.0              # Decent liquidity requirement
STALE_ORDER_TIMEOUT=35.0
MAX_CONTRACTS_PER_ASSET=2        # Can hold 5m + 15m on same asset
CLOSE_USE_MARKET_PRICE=true
ORDER_POLL_INTERVAL=2.5
ORDER_POLL_MAX_WAIT=40.0

# ===== SAFETY FILTERS — STILL STRICT ENOUGH =====
MIN_POLY_PRICE=0.18              # Avoid ultra-cheap contracts
MAX_POLY_PRICE=0.60              # Avoid very expensive ones
MAX_SIMULTANEOUS_POS=3           # Max 3 positions at once (good aggression)
MAX_CONTRACTS_PER_POS=18.0       # Slightly larger size allowed
MAX_EDGE_PCT=0.14                # Reject only the most suspicious edges

# ===== KALSHI — OFF (maximizes trades in paper mode) =====
KALSHI_CONFLUENCE_REQUIRED=false

# ===== CONNECTIONS (unchanged) =====
BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# ===== CREDENTIALS — ROTATE THESE =====
POLY_PRIVATE_KEY=
POLY_FUNDER=
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ===== UI =====
DASHBOARD_REFRESH_SECONDS=2